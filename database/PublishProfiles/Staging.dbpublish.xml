<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <IncludeCompositeObjects>True</IncludeCompositeObjects>
    <TargetDatabaseName>MaterialPurchase</TargetDatabaseName>
    <DeployScriptFileName>MaterialPurchase.sql</DeployScriptFileName>
    <TargetConnectionString>Data Source=DCVMSQLTST01;Integrated Security=True;Pooling=False</TargetConnectionString>
    <ScriptDatabaseOptions>False</ScriptDatabaseOptions>
    <DropObjectsNotInSource>False</DropObjectsNotInSource>
    <DoNotDropPermissions>True</DoNotDropPermissions>
    <DoNotDropUsers>True</DoNotDropUsers>
    <DoNotDropLogins>True</DoNotDropLogins>
    <DoNotDropServerRoles>True</DoNotDropServerRoles>
    <DoNotDropServerRoleMembership>True</DoNotDropServerRoleMembership>
    <DoNotDropRoleMembership>True</DoNotDropRoleMembership>
    <DoNotDropPermissions>True</DoNotDropPermissions>
    <DoNotDropDatabaseRoles>True</DoNotDropDatabaseRoles>
    <DoNotDropFileTables>True</DoNotDropFileTables>
    <DoNotDropFilegroups>True</DoNotDropFilegroups>
    <DoNotDropTables>True</DoNotDropTables>
    <DoNotDropTableValuedFunctions>False</DoNotDropTableValuedFunctions>
    <DoNotDropScalarValuedFunctions>False</DoNotDropScalarValuedFunctions>
    <DoNotDropStoredProcedures>False</DoNotDropStoredProcedures>
